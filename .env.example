# Copy this file to `.env` and fill in values.
# Never commit `.env` (API keys). `.env.example` is safe to commit.

# Required: OpenAI API key (https://platform.openai.com/api-keys)
OPENAI_API_KEY=

# Optional: vision-capable model (default in code is gpt-4o if unset)
OPENAI_MODEL=gpt-4o

# Optional: cheaper tests (quality may drop on hard screenshots)
# OPENAI_MODEL=gpt-4o-mini
